{
  "name": "@marimo-team/mdx-marimo-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for the marimo MDX integration.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "check": "vp check && vp run -r typecheck",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint --deny-warnings",
    "pack:mdx": "pnpm --filter @marimo-team/mdx-marimo pack",
    "release:check": "node scripts/check-release.mjs",
    "release:version": "pnpm --recursive --filter @marimo-team/mdx-marimo --filter @marimo-team/islands-bridge version",
    "ready": "pnpm check && pnpm test && pnpm build",
    "test": "vp run -r test",
    "typecheck": "vp run -r typecheck"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "vite-plus": "0.2.4"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
