{
  "name": "@marimo-team/mdx-marimo-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:deps && vite build && cp .output/public/_shell.html .output/public/index.html",
    "build:deps": "pnpm --filter \"$npm_package_name^...\" --if-present build",
    "clean": "rm -rf .marimo-cache .output .source dist && find content/docs -type d -name __marimo__ -prune -exec rm -rf {} +",
    "dev": "pnpm run build:deps && vite dev --host 127.0.0.1 --port 4100",
    "lint": "oxlint src source.config.ts vite.config.ts --deny-warnings",
    "serve": "serve .output/public --config serve.json -l 4100",
    "source": "fumadocs-mdx",
    "typecheck": "pnpm run build:deps && pnpm run source && tsc --noEmit"
  },
  "dependencies": {
    "@marimo-team/mdx-marimo": "workspace:*",
    "@orama/orama": "^3.1.18",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "@tanstack/start-static-server-functions": "1.167.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "^16.10.7",
    "fumadocs-mdx": "^15.0.13",
    "fumadocs-ui": "^16.10.7",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "nitro": "3.0.260610-beta",
    "serve": "^14.2.6",
    "srvx": "^0.11.21",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "8.1.3"
  }
}
