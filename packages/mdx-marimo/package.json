{
  "name": "@marimo-team/mdx-marimo",
  "version": "0.0.0",
  "description": "MDX integration that renders marimo code fences as interactive components.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/element/auto.js",
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./remark": {
      "types": "./dist/remark/index.d.ts",
      "import": "./dist/remark/index.js",
      "default": "./dist/remark/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    },
    "./element": {
      "types": "./dist/element/index.d.ts",
      "import": "./dist/element/index.js",
      "default": "./dist/element/index.js"
    },
    "./element/auto": {
      "types": "./dist/element/auto.d.ts",
      "import": "./dist/element/auto.js",
      "default": "./dist/element/auto.js"
    },
    "./extractor": {
      "types": "./dist/extractor/index.d.ts",
      "import": "./dist/extractor/index.js",
      "default": "./dist/extractor/index.js"
    },
    "./preset": {
      "types": "./dist/preset/index.d.ts",
      "import": "./dist/preset/index.js",
      "default": "./dist/preset/index.js"
    },
    "./react": {
      "types": "./dist/adapters/react/index.d.ts",
      "browser": "./dist/adapters/react/browser.js",
      "import": "./dist/adapters/react/index.js",
      "default": "./dist/adapters/react/index.js"
    },
    "./vue": {
      "types": "./dist/adapters/vue/index.d.ts",
      "import": "./dist/adapters/vue/index.js",
      "default": "./dist/adapters/vue/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "lint": "oxlint src test --deny-warnings",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@manzt/uv": "^0.8.13",
    "@mdx-js/rollup": "^3.1.1",
    "@types/mdast": "^4.0.4",
    "acorn": "^8.17.0",
    "estree-util-value-to-estree": "^3.5.0",
    "smol-toml": "^1.7.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@types/estree": "^1.0.9",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1"
  },
  "peerDependencies": {
    "@mdx-js/vue": "^3.1.1",
    "react": "^18.3.0 || ^19.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@mdx-js/vue": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
