{
  "name": "@marimo-team/mdx-marimo",
  "version": "0.0.1",
  "description": "Add reactive Python, SQL, and Markdown cells to MDX pages.",
  "keywords": [
    "marimo",
    "mdx",
    "notebook",
    "python",
    "reactive"
  ],
  "homepage": "https://github.com/marimo-team/mdx-marimo#readme",
  "bugs": {
    "url": "https://github.com/marimo-team/mdx-marimo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marimo-team/mdx-marimo.git",
    "directory": "packages/mdx-marimo"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/element/auto.js",
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./remark": {
      "types": "./dist/remark/index.d.ts",
      "import": "./dist/remark/index.js",
      "default": "./dist/remark/index.js"
    },
    "./element": {
      "types": "./dist/element/index.d.ts",
      "import": "./dist/element/index.js",
      "default": "./dist/element/index.js"
    },
    "./element/auto": {
      "types": "./dist/element/auto.d.ts",
      "import": "./dist/element/auto.js",
      "default": "./dist/element/auto.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "default": "./dist/node/index.js"
    },
    "./react": {
      "types": "./dist/adapters/react/index.d.ts",
      "import": "./dist/adapters/react/index.js",
      "default": "./dist/adapters/react/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepack": "vp run -t build",
    "test": "vp test run"
  },
  "dependencies": {
    "@manzt/uv": "^0.8.13",
    "@marimo-team/islands-bridge": "workspace:^",
    "@types/mdast": "^4.0.4",
    "acorn": "^8.17.0",
    "smol-toml": "^1.7.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@types/estree": "^1.0.9",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "bundleDependencies": [
    "@marimo-team/islands-bridge"
  ]
}
